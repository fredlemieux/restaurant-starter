{
  "name": "@restaurant/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 4321",
    "dev:stack": "docker compose -f ../../infra/docker-compose.yml up",
    "start": "astro dev --port 4321",
    "build": "astro check && astro build",
    "preview": "astro preview --port 4322",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.0",
    "@portabletext/react": "^6.0.0",
    "@restaurant/schemas": "workspace:*",
    "@restaurant/ui": "workspace:*",
    "@sanity/client": "catalog:",
    "@sanity/image-url": "catalog:",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^7.0.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "resend": "^6.0.0",
    "tailwindcss": "^4.3.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@playwright/test": "^1.61.0",
    "@restaurant/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }

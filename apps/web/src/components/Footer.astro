---
import { getRestaurant } from '@/lib/queries';

let restaurant = null;
try {
  restaurant = await getRestaurant();
} catch (err) {
  console.error('[footer] failed to load restaurant from Sanity:', err);
}
---

<footer class="border-t border-(--color-ink)/10 mt-16 py-12 text-sm text-(--color-ink)/70">
  <div class="mx-auto max-w-6xl px-6 grid gap-8 sm:grid-cols-3">
    <div>
      <p class="font-display text-2xl text-(--color-ink)">{restaurant?.name ?? 'Restaurant'}</p>
      {restaurant?.tagline && <p class="mt-1">{restaurant.tagline}</p>}
    </div>
    {restaurant?.address && (
      <div>
        <p>{restaurant.address.line1}</p>
        {restaurant.address.line2 && <p>{restaurant.address.line2}</p>}
        <p>{restaurant.address.city} {restaurant.address.postcode}</p>
        {restaurant.address.mapsUrl && (
          <a href={restaurant.address.mapsUrl} class="underline mt-2 inline-block">Get directions</a>
        )}
      </div>
    )}
    <div>
      {restaurant?.phone && <p>{restaurant.phone}</p>}
      {restaurant?.email && <a href={`mailto:${restaurant.email}`} class="underline">{restaurant.email}</a>}
    </div>
  </div>
  <p class="mt-10 text-center text-xs text-(--color-ink)/50">© {new Date().getFullYear()} {restaurant?.name ?? 'Restaurant'}</p>
</footer>

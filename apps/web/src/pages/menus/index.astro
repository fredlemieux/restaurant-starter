---
import Base from '@/layouts/Base.astro';
import { getMenus } from '@/lib/queries';

const menus = await getMenus();
---

<Base title="Menus" description="Our menus">
  <div class="mx-auto max-w-3xl px-6 py-24">
    <h1 class="text-5xl mb-8">Menus</h1>
    <ul class="space-y-4">
      {menus.map((m) => (
        <li>
          <a href={`/menus/${m.slug.current}`} class="block py-3 border-b border-ink/10 hover:bg-ink/5 -mx-4 px-4 rounded">
            <span class="text-2xl">{m.title}</span>
            {m.available && <span class="block text-sm text-ink/70">{m.available}</span>}
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>

---
import Base from '@/layouts/Base.astro';
import { Button } from '@restaurant/ui';
---

<Base title="Private hire" description="Host your event with us">
  <div class="mx-auto max-w-3xl px-6 py-24">
    <h1 class="text-5xl mb-8">Private hire</h1>
    <p class="text-lg mb-6">
      Available for full or partial buy-outs Monday through Wednesday and seasonal Sundays.
      Capacity from 12 to 90 guests across the dining room and private snug.
    </p>
    <p class="mb-8">
      Tell us about your event using the form below and our events lead will get back to you within one working day.
    </p>
    <a href="/contact?subject=private-hire">
      <Button size="lg">Get in touch</Button>
    </a>
  </div>
</Base>

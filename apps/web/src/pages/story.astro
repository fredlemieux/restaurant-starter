---
import Base from '@/layouts/Base.astro';
import PortableTextBlock from '@/components/PortableTextBlock.astro';
import { getRestaurant } from '@/lib/queries';

const restaurant = await getRestaurant();
---

<Base title="Our story" description={restaurant?.tagline}>
  <div class="mx-auto max-w-3xl px-6 py-24">
    <h1 class="text-5xl mb-8">Our story</h1>
    <PortableTextBlock blocks={restaurant?.about} />
  </div>
</Base>
